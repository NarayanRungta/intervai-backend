APP_NAME=Interview Monitoring Backend
APP_VERSION=1.0.0
APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8001
CORS_ORIGINS=http://localhost:3000

CAMERA_INDEX=0
FRAME_WIDTH=640
FRAME_HEIGHT=480
TARGET_FPS=5
WS_INTERVAL_MS=300
CAMERA_WARMUP_FRAMES=5
CAMERA_READ_RETRIES=1

EYE_HORIZONTAL_THRESHOLD=0.16
EYE_DOWN_THRESHOLD=0.65
HEAD_YAW_THRESHOLD=18
HEAD_PITCH_THRESHOLD=16
INVERT_HEAD_YAW=false
FACE_ABSENCE_GRACE_SECONDS=1.2
TEMPORAL_SMOOTHING_ALPHA=0.65
DIRECTION_HISTORY_SIZE=5
REUSE_LAST_LANDMARKS_ON_MISS=true

YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONF_THRESHOLD=0.35
YOLO_DEVICE=cpu
PHONE_DETECTION_FRAME_SKIP=2

MEDIAPIPE_MIN_DETECTION_CONFIDENCE=0.5
MEDIAPIPE_MIN_TRACKING_CONFIDENCE=0.5
MEDIAPIPE_BACKEND=auto
MEDIAPIPE_FACE_LANDMARKER_MODEL_PATH=face_landmarker.task
FACE_RETRY_WITH_ENHANCED_FRAME=true

SUSPICION_EYE_WEIGHT=0.35
SUSPICION_HEAD_WEIGHT=0.35
SUSPICION_PHONE_WEIGHT=0.30

CELERY_ENABLED=false
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_QUEUE=monitoring
CELERY_TASK_TIMEOUT_MS=4000
